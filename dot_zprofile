# Homebrew (macOS Apple Silicon, macOS Intel, Linuxbrew)
for brew_path in /opt/homebrew/bin/brew /usr/local/bin/brew /home/linuxbrew/.linuxbrew/bin/brew; do
    if [ -x "$brew_path" ]; then
        eval "$("$brew_path" shellenv)"
        break
    fi
done
unset brew_path

# Reuse common login-shell environment settings.
if [ -f "$HOME/.profile" ]; then
    . "$HOME/.profile"
fi